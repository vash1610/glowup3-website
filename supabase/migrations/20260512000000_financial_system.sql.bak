-- GlowUp3 Financial Tracking System
-- Tables for accounts, transactions, escrow, and Stripe linking

-- ============================================
-- ACCOUNTS TABLE (User money balances)
-- ============================================
CREATE TABLE IF NOT EXISTS accounts (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    owner_id TEXT NOT NULL, -- References user ID from auth or users table
    owner_type TEXT NOT NULL CHECK (owner_type IN ('customer', 'professional')),
    balance BIGINT DEFAULT 0, -- Stored in CZK cents (hellers)
    currency VARCHAR(3) DEFAULT 'CZK',
    status TEXT DEFAULT 'active' CHECK (status IN ('active', 'frozen', 'suspended')),
    stripe_customer_id TEXT,
    stripe_account_id TEXT, -- For professionals (Connect accounts)
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    UNIQUE(owner_id, owner_type)
);

-- Index for faster lookups
CREATE INDEX IF NOT EXISTS idx_accounts_owner ON accounts(owner_id, owner_type);
CREATE INDEX IF NOT EXISTS idx_accounts_stripe ON accounts(stripe_customer_id, stripe_account_id);

-- ============================================
-- WALLET_TRANSACTIONS TABLE (All money movements)
-- ============================================
CREATE TABLE IF NOT EXISTS wallet_transactions (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    account_id UUID NOT NULL REFERENCES accounts(id) ON DELETE CASCADE,
    type TEXT NOT NULL CHECK (type IN (
        'deposit',           -- Money added (Stripe payment, top-up)
        'withdrawal',        -- Money removed (payout, withdrawal)
        'transfer_in',       -- Received from another account
        'transfer_out',      -- Sent to another account
        'escrow_hold',       -- Money held for appointment
        'escrow_release',    -- Money released to pro
        'refund',            -- Money refunded
        'platform_fee',      -- Platform commission taken
        'adjustment'         -- Manual admin adjustment
    )),
    amount BIGINT NOT NULL, -- Stored in CZK cents
    fee BIGINT DEFAULT 0,   -- Transaction fee in CZK cents
    balance_before BIGINT NOT NULL,
    balance_after BIGINT NOT NULL,
    reference_account_id UUID REFERENCES accounts(id), -- For transfers
    status TEXT DEFAULT 'pending' CHECK (status IN ('pending', 'completed', 'failed', 'cancelled')),
    stripe_payment_intent_id TEXT,
    stripe_charge_id TEXT,
    stripe_transfer_id TEXT,
    stripe_payout_id TEXT,
    appointment_id TEXT, -- Link to appointment if applicable
    description TEXT,
    metadata JSONB DEFAULT '{}',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    completed_at TIMESTAMP WITH TIME ZONE
);

-- Indexes for fast queries
CREATE INDEX IF NOT EXISTS idx_wallet_tx_account ON wallet_transactions(account_id);
CREATE INDEX IF NOT EXISTS idx_wallet_tx_type ON wallet_transactions(type);
CREATE INDEX IF NOT EXISTS idx_wallet_tx_status ON wallet_transactions(status);
CREATE INDEX IF NOT EXISTS idx_wallet_tx_stripe ON wallet_transactions(stripe_payment_intent_id, stripe_charge_id);
CREATE INDEX IF NOT EXISTS idx_wallet_tx_appointment ON wallet_transactions(appointment_id);
CREATE INDEX IF NOT EXISTS idx_wallet_tx_created ON wallet_transactions(created_at DESC);

-- ============================================
-- ESCROW_TRANSACTIONS TABLE (Held deposits)
-- ============================================
CREATE TABLE IF NOT EXISTS escrow_transactions (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    appointment_id TEXT UNIQUE NOT NULL,
    customer_account_id UUID NOT NULL REFERENCES accounts(id),
    professional_account_id UUID NOT NULL REFERENCES accounts(id),
    amount BIGINT NOT NULL, -- In CZK cents
    released_amount BIGINT DEFAULT 0,
    refunded_amount BIGINT DEFAULT 0,
    platform_fee_amount BIGINT DEFAULT 0,
    status TEXT DEFAULT 'held' CHECK (status IN ('held', 'released', 'refunded', 'partially_released', 'cancelled')),
    hold_date TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    release_date TIMESTAMP WITH TIME ZONE,
    released_to_pro BOOLEAN DEFAULT FALSE,
    stripe_payment_intent_id TEXT,
    stripe_refund_id TEXT,
    cancellation_reason TEXT,
    metadata JSONB DEFAULT '{}',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Indexes
CREATE INDEX IF NOT EXISTS idx_escrow_appointment ON escrow_transactions(appointment_id);
CREATE INDEX IF NOT EXISTS idx_escrow_customer ON escrow_transactions(customer_account_id);
CREATE INDEX IF NOT EXISTS idx_escrow_professional ON escrow_transactions(professional_account_id);
CREATE INDEX IF NOT EXISTS idx_escrow_status ON escrow_transactions(status);
CREATE INDEX IF NOT EXISTS idx_escrow_hold_date ON escrow_transactions(hold_date);

-- ============================================
-- STRIPE_ACCOUNTS TABLE (Link users to Stripe)
-- ============================================
CREATE TABLE IF NOT EXISTS stripe_accounts (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id TEXT NOT NULL,
    stripe_customer_id TEXT UNIQUE,
    stripe_account_id TEXT UNIQUE, -- For professionals (Connect accounts)
    stripe_email TEXT,
    is_verified BOOLEAN DEFAULT FALSE,
    verification_date TIMESTAMP WITH TIME ZONE,
    default_payment_method_id TEXT,
    metadata JSONB DEFAULT '{}',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Indexes
CREATE INDEX IF NOT EXISTS idx_stripe_user ON stripe_accounts(user_id);
CREATE INDEX IF NOT EXISTS idx_stripe_customer ON stripe_accounts(stripe_customer_id);
CREATE INDEX IF NOT EXISTS idx_stripe_account ON stripe_accounts(stripe_account_id);

-- ============================================
-- RECONCILIATION_LOGS TABLE (Audit trail)
-- ============================================
CREATE TABLE IF NOT EXISTS reconciliation_logs (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    reconciliation_date DATE NOT NULL,
    reconciliation_type TEXT NOT NULL CHECK (reconciliation_type IN ('daily_balance', 'weekly_audit', 'manual', 'webhook', 'scheduled')),
    supabase_total BIGINT NOT NULL, -- Sum of all account balances in CZK cents
    stripe_total BIGINT NOT NULL,   -- Sum from Stripe
    discrepancy_amount BIGINT DEFAULT 0,
    supabase_transaction_count INTEGER DEFAULT 0,
    stripe_transaction_count INTEGER DEFAULT 0,
    count_discrepancy INTEGER DEFAULT 0,
    status TEXT DEFAULT 'pending' CHECK (status IN ('pending', 'in_progress', 'completed', 'failed', 'alert_sent')),
    severity TEXT DEFAULT 'info' CHECK (severity IN ('debug', 'info', 'warning', 'critical', 'fraud')),
    findings JSONB DEFAULT '[]',
    missing_transactions JSONB DEFAULT '[]', -- In Stripe but not Supabase
    extra_transactions JSONB DEFAULT '[]',    -- In Supabase but not Stripe
    discrepancy_transactions JSONB DEFAULT '[]', -- Amount mismatches
    checked_by TEXT, -- User or system
    notes TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    completed_at TIMESTAMP WITH TIME ZONE
);

-- Indexes
CREATE INDEX IF NOT EXISTS idx_recon_date ON reconciliation_logs(reconciliation_date DESC);
CREATE INDEX IF NOT EXISTS idx_recon_type ON reconciliation_logs(reconciliation_type);
CREATE INDEX IF NOT EXISTS idx_recon_status ON reconciliation_logs(status);
CREATE INDEX IF NOT EXISTS idx_recon_severity ON reconciliation_logs(severity);

-- ============================================
-- HELPER FUNCTIONS
-- ============================================

-- Function to update updated_at timestamp
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ language 'plpgsql';

-- Triggers for updated_at
CREATE TRIGGER update_accounts_updated_at
    BEFORE UPDATE ON accounts
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_escrow_updated_at
    BEFORE UPDATE ON escrow_transactions
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_stripe_accounts_updated_at
    BEFORE UPDATE ON stripe_accounts
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

-- Function to create account for user
CREATE OR REPLACE FUNCTION create_account_for_user(
    p_owner_id TEXT,
    p_owner_type TEXT
)
RETURNS UUID AS $$
DECLARE
    v_account_id UUID;
BEGIN
    -- Check if account already exists
    SELECT id INTO v_account_id
    FROM accounts
    WHERE owner_id = p_owner_id AND owner_type = p_owner_type;
    
    IF v_account_id IS NOT NULL THEN
        RETURN v_account_id;
    END IF;
    
    -- Create new account
    INSERT INTO accounts (owner_id, owner_type)
    VALUES (p_owner_id, p_owner_type)
    RETURNING id INTO v_account_id;
    
    RETURN v_account_id;
END;
$$ LANGUAGE plpgsql;

-- ============================================
-- ROW LEVEL SECURITY (RLS)
-- ============================================

ALTER TABLE accounts ENABLE ROW LEVEL SECURITY;
ALTER TABLE wallet_transactions ENABLE ROW LEVEL SECURITY;
ALTER TABLE escrow_transactions ENABLE ROW LEVEL SECURITY;
ALTER TABLE stripe_accounts ENABLE ROW LEVEL SECURITY;
ALTER TABLE reconciliation_logs ENABLE ROW LEVEL SECURITY;

-- Admin can see all
CREATE POLICY "Admin can view all accounts" ON accounts FOR SELECT USING (
    auth.jwt() ->> 'role' = 'admin'
);

CREATE POLICY "Admin can view all transactions" ON wallet_transactions FOR SELECT USING (
    auth.jwt() ->> 'role' = 'admin'
);

CREATE POLICY "Admin can view all escrow" ON escrow_transactions FOR SELECT USING (
    auth.jwt() ->> 'role' = 'admin'
);

CREATE POLICY "Admin can view all stripe accounts" ON stripe_accounts FOR SELECT USING (
    auth.jwt() ->> 'role' = 'admin'
);

CREATE POLICY "Admin can view reconciliation logs" ON reconciliation_logs FOR SELECT USING (
    auth.jwt() ->> 'role' = 'admin'
);

-- Service role can do everything (for API endpoints)
CREATE POLICY "Service role full access accounts" ON accounts FOR ALL USING (
    auth.role() = 'service_role'
);

CREATE POLICY "Service role full access transactions" ON wallet_transactions FOR ALL USING (
    auth.role() = 'service_role'
);

CREATE POLICY "Service role full access escrow" ON escrow_transactions FOR ALL USING (
    auth.role() = 'service_role'
);

CREATE POLICY "Service role full access stripe" ON stripe_accounts FOR ALL USING (
    auth.role() = 'service_role'
);

CREATE POLICY "Service role full access reconciliation" ON reconciliation_logs FOR ALL USING (
    auth.role() = 'service_role'
);

-- ============================================
-- COMMENTS
-- ============================================

COMMENT ON TABLE accounts IS 'User accounts holding money balances (in CZK cents)';
COMMENT ON COLUMN accounts.balance IS 'Balance stored in CZK cents/hellers to avoid floating point issues';
COMMENT ON COLUMN accounts.stripe_customer_id IS 'Stripe Customer ID for customer payments';
COMMENT ON COLUMN accounts.stripe_account_id IS 'Stripe Connect Account ID for professionals to receive payouts';

COMMENT ON TABLE wallet_transactions IS 'Ledger of all money movements in the system';
COMMENT ON COLUMN wallet_transactions.amount IS 'Amount in CZK cents';
COMMENT ON COLUMN wallet_transactions.fee IS 'Transaction fee in CZK cents';

COMMENT ON TABLE escrow_transactions IS 'Tracks money held in escrow for appointments';
COMMENT ON COLUMN escrow_transactions.amount IS 'Original amount held in CZK cents';

COMMENT ON TABLE stripe_accounts IS 'Links GlowUp3 users to their Stripe accounts';

COMMENT ON TABLE reconciliation_logs IS 'Audit trail for financial reconciliation between Supabase and Stripe';