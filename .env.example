# Stripe (for payments)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Admin API - Required for server-side operations, including admin login
# itself (get from Supabase Dashboard > Settings > API). Keep this out of any
# client-exposed (EXPO_PUBLIC_/NEXT_PUBLIC_) variable name.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend - Required to deliver admin 2FA login codes by email.
# Without this set, login codes are only logged to the server console, which
# in production means nobody can actually complete login.
RESEND_API_KEY=your_resend_api_key_here
ADMIN_EMAIL_FROM="Todayly Admin <admin@yourdomain.com>"

# MiniMax AI - For AI-powered database queries (get from MiniMax API dashboard)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_API_URL=https://api.minimax.chat/v1

# Anthropic - Powers the AI ticket assistant (Beta) on payment/appointment tickets.
# Get a key from console.anthropic.com (separate from a Claude Pro subscription -
# this is pay-as-you-go API billing). Without it, "Get AI Diagnosis" returns a
# clear error instead of crashing.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
